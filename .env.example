# ==============================================================================
# Solana Stablecoin Standard - Environment Configuration
# ==============================================================================
# Copy to .env and fill in values: cp .env.example .env

# --- Solana RPC ---
SOLANA_RPC_URL=http://127.0.0.1:8899
# SOLANA_RPC_URL=https://api.devnet.solana.com

# --- Program IDs ---
SSS_TOKEN_PROGRAM_ID=tCe3w68q2eo752dzozjGrV8rwhuynfz6T4HtquHf1Gz
SSS_TRANSFER_HOOK_PROGRAM_ID=A7UUA9Dbn9XokzuTqMCD9ka4y7x1pQBHJERa92dGAHKB

# --- Authority ---
AUTHORITY_KEYPAIR=~/.config/solana/id.json
# For Docker: path on host to mount into container
AUTHORITY_KEYPAIR_PATH=~/.config/solana/id.json

# --- Mint (set after initialize instruction) ---
MINT_ADDRESS=

# --- Backend Server ---
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# --- Compliance ---
ENABLE_SANCTIONS_SCREENING=false
SANCTIONS_API_URL=

# --- API Authentication ---
# If set, /mint and /burn routes require `Authorization: Bearer <key>` header.
# If unset, all requests are allowed (dev mode).
API_KEY=

# --- CORS ---
# Comma-separated list of allowed origins. Defaults to http://localhost:3000.
CORS_ORIGINS=http://localhost:3000

# --- Webhook ---
# HMAC-SHA256 secret for signing webhook payloads (X-Webhook-Signature header).
WEBHOOK_SECRET=

# --- Frontend ---
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8899
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
