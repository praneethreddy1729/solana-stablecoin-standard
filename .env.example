# ==============================================================================
# Solana Stablecoin Standard - Environment Configuration
# ==============================================================================
# Copy to .env and fill in values: cp .env.example .env

# --- Solana RPC ---
SOLANA_RPC_URL=http://127.0.0.1:8899
# SOLANA_RPC_URL=https://api.devnet.solana.com

# --- Program IDs ---
SSS_TOKEN_PROGRAM_ID=8PRbAdtmGWZRjQJpsybTgojq5UkYsCSujTERY3QhC9LW
SSS_TRANSFER_HOOK_PROGRAM_ID=J9eLtU1WpAThPvysxzLKkYhoBZaMQJPwjNStTKSokJcf

# --- Authority ---
AUTHORITY_KEYPAIR=~/.config/solana/id.json
# For Docker: path on host to mount into container
AUTHORITY_KEYPAIR_PATH=~/.config/solana/id.json

# --- Mint (set after initialize instruction) ---
MINT_ADDRESS=

# --- Backend Server ---
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# --- Compliance ---
ENABLE_SANCTIONS_SCREENING=false
SANCTIONS_API_URL=

# --- Frontend ---
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8899
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
